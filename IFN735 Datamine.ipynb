      "source": "# Load the real LIMS-style QC export.\nsource_path = Path(r\"/Users/linhlinh/Downloads/ResultSet.csv\")\nusecols = [\n    \"ANALYTICAL_TYPE\", \"JOB_CODE\", \"NUMERIC_FINAL_VALUE\", \"ANALYSED_DATE\",\n    \"ANALYTE_CODE\", \"STANDARD_STATUS\", \"PRECISION_STATUS\",\n    \"INTERNAL_MIN_VALUE\", \"INTERNAL_MAX_VALUE\",\n    \"INTERNAL_MIN_WARNING_VALUE\", \"INTERNAL_MAX_WARNING_VALUE\",\n    \"INTERNAL_TARGET_VALUE\", \"PARENT_NUMERIC_FINAL_VALUE\",\n    \"UNIT_CODE\", \"INSTRUMENT_ID\"\n]\nraw_df = pd.read_csv(source_path, usecols=usecols, low_memory=False)\nraw_df[\"ANALYSED_DATE\"] = pd.to_datetime(raw_df[\"ANALYSED_DATE\"], errors=\"coerce\")\n\ndf = pd.DataFrame({\n    \"SampleID\": raw_df[\"JOB_CODE\"].fillna(\"JOB-UNKNOWN\") + \"-\" + raw_df.index.astype(str),\n    \"SampleType\": raw_df[\"ANALYTICAL_TYPE\"].fillna(\"Unknown\"),\n    \"AnalysisDate\": raw_df[\"ANALYSED_DATE\"],\n    \"Value\": pd.to_numeric(raw_df[\"NUMERIC_FINAL_VALUE\"], errors=\"coerce\"),\n    \"ExpectedValue\": pd.to_numeric(raw_df[\"INTERNAL_TARGET_VALUE\"], errors=\"coerce\"),\n    \"LowerLimit\": pd.to_numeric(raw_df[\"INTERNAL_MIN_VALUE\"], errors=\"coerce\"),\n    \"UpperLimit\": pd.to_numeric(raw_df[\"INTERNAL_MAX_VALUE\"], errors=\"coerce\"),\n    \"WarningLower\": pd.to_numeric(raw_df[\"INTERNAL_MIN_WARNING_VALUE\"], errors=\"coerce\"),\n    \"WarningUpper\": pd.to_numeric(raw_df[\"INTERNAL_MAX_WARNING_VALUE\"], errors=\"coerce\"),\n    \"ParentValue\": pd.to_numeric(raw_df[\"PARENT_NUMERIC_FINAL_VALUE\"], errors=\"coerce\"),\n    \"Analyte\": raw_df[\"ANALYTE_CODE\"].fillna(\"Unknown\"),\n    \"JobCode\": raw_df[\"JOB_CODE\"].fillna(\"JOB-UNKNOWN\"),\n    \"StandardStatus\": raw_df[\"STANDARD_STATUS\"].fillna(\"\"),\n    \"PrecisionStatus\": raw_df[\"PRECISION_STATUS\"].fillna(\"\"),\n})\n\ndf[\"SampleType\"] = df[\"SampleType\"].replace({\n    \"Replicate\": \"Duplicate samples\",\n    \"Duplicate\": \"Duplicate samples\",\n    \"Blank\": \"Blank samples\",\n    \"Standard\": \"Standard samples\",\n})\ndf[\"DuplicateGroup\"] = np.where(df[\"SampleType\"].eq(\"Duplicate samples\"), df[\"JobCode\"] + \"-\" + df[\"Analyte\"], np.nan)\ndf[\"ExpectedValue\"] = df[\"ExpectedValue\"].fillna(df[\"ParentValue\"])\ndf[\"ExpectedValue\"] = df[\"ExpectedValue\"].fillna(df.groupby([\"Analyte\", \"SampleType\"])[\"Value\"].transform(\"median\"))\ndf[\"ExpectedValue\"] = df[\"ExpectedValue\"].fillna(df.groupby(\"Analyte\")[\"Value\"].transform(\"median\"))\ndf[\"ExpectedValue\"] = df[\"ExpectedValue\"].fillna(df[\"Value\"].median())\n\ndf[\"LowerLimitSource\"] = np.where(df[\"LowerLimit\"].notna(), \"Real\", \"Proxy\")\ndf[\"UpperLimitSource\"] = np.where(df[\"UpperLimit\"].notna(), \"Real\", \"Proxy\")\ndf[\"LowerLimit\"] = df[\"LowerLimit\"].fillna(df[\"ExpectedValue\"] * 0.90)\ndf[\"UpperLimit\"] = df[\"UpperLimit\"].fillna(df[\"ExpectedValue\"] * 1.10)\n\nspan = df[\"UpperLimit\"] - df[\"LowerLimit\"]\ndf[\"WarningLower\"] = df[\"WarningLower\"].fillna(df[\"LowerLimit\"] + span * 0.10)\ndf[\"WarningUpper\"] = df[\"WarningUpper\"].fillna(df[\"UpperLimit\"] - span * 0.10)\n\ndf = df.dropna(subset=[\"AnalysisDate\", \"Value\"]).sort_values(\"AnalysisDate\").reset_index(drop=True)\n\nprint(\"Loaded real QC data from:\", source_path)\nprint(\"Rows after cleaning:\", len(df))\ndf.head(10)\n"
    },
