td>\n      <td>2.26</td>\n      <td>NaN</td>\n    </tr>\n    <tr>\n      <td>TSV_LB0002628992-99991</td>\n      <td>Duplicate samples</td>\n      <td>0.02</td>\n      <td>0.02</td>\n      <td>0.00</td>\n      <td>0.14</td>\n      <td>0.17</td>\n      <td>4.28</td>\n      <td>NaN</td>\n    </tr>\n    <tr>\n      <td>TSV_LB0002628992-99990</td>\n      <td>Duplicate samples</td>\n      <td>47.86</td>\n      <td>52.47</td>\n      <td>-4.60</td>\n      <td>36.35</td>\n      <td>16.28</td>\n      <td>9.17</td>\n      <td>NaN</td>\n    </tr>\n    <tr>\n      <td>TSV_LB0002628992-99989</td>\n      <td>Standard samples</td>\n      <td>35.66</td>\n      <td>30.10</td>\n      <td>5.56</td>\n      <td>9.70</td>\n      <td>17.33</td>\n      <td>NaN</td>\n      <td>NaN</td>\n    </tr>\n  </tbody>\n</table>"
