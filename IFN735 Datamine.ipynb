      "source": "# Risk scoring\nstd_scale = max(float(df[\"RollingStd\"].std()), 1.0)\ndeviation_component = np.clip(df[\"DeviationPct\"].abs(), 0, 40) / 40 * 30\nrolling_component = np.clip(df[\"RollingStd\"] / std_scale, 0, 3) / 3 * 20\nrpd_component = np.clip(df[\"RPD\"].fillna(0), 0, 50) / 50 * 20\nrecovery_gap = np.where(df[\"SampleType\"].eq(\"MatrixSpike\"), np.abs(df[\"RecoveryPct\"].fillna(100) - 100), 0)\nrecovery_component = np.clip(np.maximum(recovery_gap - 10, 0), 0, 40) / 40 * 15\nrule_component = df[\"RuleFlag\"].map({\"Green\": 0, \"Yellow\": 7.5, \"Red\": 15}).astype(float)\n\ndf[\"RiskScore\"] = (deviation_component + rolling_component + rpd_component + recovery_component + rule_component).round(2)\ndf[\"RiskLevel\"] = pd.cut(df[\"RiskScore\"], bins=[-0.01, 30, 60, 100], labels=[\"Low\", \"Medium\", \"High\"])\n\nrisk_summary = df[\"RiskLevel\"].value_counts().rename_axis(\"RiskLevel\").reset_index(name=\"Count\")\nrisk_summary[\"Percent\"] = (risk_summary[\"Count\"] / len(df) * 100).round(2)\nrisk_summary[\"RiskLevel\"] = pd.Categorical(risk_summary[\"RiskLevel\"], categories=[\"Low\", \"Medium\", \"High\"], ordered=True)\nrisk_summary = risk_summary.sort_values(\"RiskLevel\")\n\ntop_10_high_risk = df.sort_values(\"RiskScore\", ascending=False).head(10)[\n    [\"SampleID\", \"SampleType\", \"Analyte\", \"AnalysisDate\", \"Value\", \"RuleFlag\", \"IForestAnomaly\", \"RiskScore\", \"RiskLevel\"]\n]\n\nrisk_summary\ntop_10_high_risk\n"
